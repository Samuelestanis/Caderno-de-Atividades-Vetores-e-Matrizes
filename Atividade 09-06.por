programa {
  funcao inicio() {
    inteiro i[4]

    escreva("Digite um valor:")
    leia(i[0])
    escreva("Digite um valor:")
    leia(i[1])
    escreva("Digite um valor:")
    leia(i[2])
    escreva("Digite um valor:")
    leia(i[3])

    se(i[0]==i[3]){

    escreva("Os valores do índice 0 e do índice 3 são iguais")

    }
    senao{

    escreva("Os valores do índice 0 e do índice 3 são diferentes")

    }

  }
}
