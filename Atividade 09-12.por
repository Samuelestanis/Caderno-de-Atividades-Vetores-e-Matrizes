programa {
  funcao inicio() {
    cadeia matriz[2][2]

    escreva("Quem sentará no linha 0,coluna 0:")
    leia(matriz[0][0])
    escreva("Quem sentará no linha 0,coluna 1:")
    leia(matriz[0][1])
    escreva("Quem sentará no linha 1,coluna 0:")
    leia(matriz[1][0])
    escreva("Quem sentará no linha 1,coluna 1:")
    leia(matriz[1][1])

    escreva(matriz[0][0],"\t",matriz[0][1],"\n")
    escreva(matriz[1][0],"\t",matriz[1][1])
  }
 }
