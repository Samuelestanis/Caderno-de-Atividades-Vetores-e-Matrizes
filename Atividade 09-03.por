programa {
  funcao inicio() {
    real i[3],soma

    escreva("Digite o valor do indice desse vetor iniciando em :")
    leia(i[0])
    escreva("Digite o valor do indice desse vetor iniciando em :")
    leia(i[1])

    soma=i[0]+i[1]
    i[2]=soma

    escreva("[",i[0],",",i[1],",",i[2],"]")
   

    
    
  }
}
